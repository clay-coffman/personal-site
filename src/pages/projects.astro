---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Footer from "~/components/Footer.astro";
import Icon from "~/components/Icon.astro";
import { profileData } from "~/data/profile";

const projects = profileData.projects;
---

<BaseLayout
  title="Clay Coffman — Projects"
  description="Things I'm building or have built."
>
  <main class="px-16 py-16 max-md:px-5 max-md:py-12">
    <div class="mb-12 max-md:mb-8">
      <div
        class="mb-3 font-mono text-[11px] uppercase tracking-[2px] text-accent"
      >
        {projects.length} repos
      </div>
      <h1 class="text-h1 m-0">Projects</h1>
    </div>
    <div class="grid gap-8 md:grid-cols-3 max-md:grid-cols-1 max-md:gap-5">
      {
        projects.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-t-2 border-accent py-6 no-underline-anim text-foreground max-md:py-5"
          >
            <div class="mb-3 flex items-baseline justify-between gap-3">
              <h3 class="text-h3-sm m-0 text-foreground transition-colors group-hover:text-accent">
                {p.title}
              </h3>
              {p.language && (
                <span class="shrink-0 bg-accent-soft px-2 py-0.5 font-mono text-[10px] uppercase tracking-[1px] text-accent">
                  {p.language}
                </span>
              )}
            </div>
            <p class="m-0 text-[14.5px] leading-[1.55] text-foreground-light max-md:text-sm">
              {p.description}
            </p>
            <div class="mt-3.5 flex items-center gap-1 font-mono text-[11px] uppercase tracking-[1px] text-accent">
              <span>view on github</span>
              <Icon name="external-link" size={11} class="opacity-60" />
            </div>
          </a>
        ))
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
