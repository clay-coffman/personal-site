---
import BaseLayout from "~/layouts/BaseLayout.astro";
import AmbientPlate from "~/components/AmbientPlate.astro";
import HeroSection from "~/components/HeroSection.astro";
import ExperienceSection from "~/components/ExperienceSection.astro";
import CodeSection from "~/components/CodeSection.astro";
import BooksSection from "~/components/BooksSection.astro";
import PhotosSection from "~/components/PhotosSection.astro";
import WritingSection from "~/components/WritingSection.astro";
import SideRail from "~/components/SideRail.astro";
import HomeFooter from "~/components/HomeFooter.astro";
import { profileData } from "~/data/profile";
---

<BaseLayout
  title="Clay Coffman"
  description="Personal site for Clay Coffman — what I'm building, what I'm learning, books I keep coming back to, photos, and occasional writing."
>
  <AmbientPlate />
  <SideRail />
  <main class="relative z-[1]">
    <HeroSection profile={profileData} />
    <ExperienceSection experiences={profileData.experiences} />
    <CodeSection
      projects={profileData.projects}
      skills={profileData.skills}
    />
    <BooksSection />
    <PhotosSection />
    <WritingSection />
    <HomeFooter profile={profileData} />
  </main>
</BaseLayout>
