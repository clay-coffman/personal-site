---
import BaseLayout from "~/layouts/BaseLayout.astro";
import HighlightList from "~/components/HighlightList.astro";
import Footer from "~/components/Footer.astro";
import { highlights } from "~/data/highlights";
---

<BaseLayout
  title="Clay Coffman — Highlights"
  description="Passages from articles, books, and newsletters that struck me enough to save."
>
  <div data-nav-sentinel aria-hidden="true"></div>
  <main class="px-16 py-16 max-md:px-5 max-md:py-12">
    <div class="mb-8">
      <h1 class="text-h2 mb-3">Highlights</h1>
      <p class="text-muted">
        Passages from articles, books, and newsletters that struck me enough
        to save and come back to.
      </p>
      <p class="text-muted">
        <em
          >Synced daily from Readwise; anything I tag <code>publish</code>
          lands here.</em
        >
      </p>
    </div>
    <HighlightList highlights={highlights} />
  </main>
  <Footer />
</BaseLayout>
