---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Footer from "~/components/Footer.astro";
import SubscribeForm from "~/components/SubscribeForm.astro";
---

<BaseLayout
  title="Subscribe — Clay Coffman"
  description="Get new posts by email. Infrequent, no filler, unsubscribe anytime."
>
  <main class="px-16 py-16 max-md:px-5 max-md:py-12">
    <div class="mb-12 max-md:mb-8">
      <div
        class="mb-3 font-mono text-label uppercase tracking-[2px] text-accent"
      >
        newsletter
      </div>
      <h1 class="text-h1 m-0">Subscribe</h1>
    </div>
    <div class="mx-auto max-w-xl">
      <p class="mb-8 text-body text-foreground-light">
        If you'd rather get new posts in your inbox than check back here,
        drop your email below. You'll get an email the moment something new
        ships — nothing else. No marketing, no drip sequence, no other
        senders. Unsubscribe link in every email.
      </p>
      <p class="mb-8 text-detail text-muted">
        Prefer RSS? The feed lives at <a
          href="/rss.xml"
          class="text-accent hover:text-accent-dark">/rss.xml</a
        >.
      </p>
    </div>
    <SubscribeForm heading="Email" copy="You'll confirm via one click in a follow-up email." compact />
  </main>
  <Footer />
</BaseLayout>
