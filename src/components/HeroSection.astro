---
import type { ProfileData } from "~/data/profile";

interface Props {
  profile: ProfileData;
}

const { profile } = Astro.props;

const skillCount = Object.values(profile.skills).flat().length;

const rows = [
  {
    label: "Experience",
    count: profile.experiences.length,
    meta: "since 2015",
    href: "#experience",
  },
  {
    label: "Projects",
    count: profile.projects.length,
    meta: "recent",
    href: "#projects",
  },
  {
    label: "Skills",
    count: skillCount,
    meta: "current stack",
    href: "#skills",
  },
  {
    label: "Education",
    count: profile.education.length,
    meta: "",
    href: "#education",
  },
];

const pad2 = (n: number) => String(n).padStart(2, "0");
---

<section
  id="hero"
  class="flex min-h-screen flex-col gap-14 px-16 pt-24 pb-18 md:gap-14 md:px-16 md:pt-24 md:pb-18 max-md:min-h-auto max-md:gap-9 max-md:px-5 max-md:pt-12 max-md:pb-12"
>
  <div
    class="flex items-center justify-between font-mono text-[11px] uppercase tracking-[1px] text-muted"
  >
    <span>{profile.name}</span>
    <span>40.76° N · 111.89° W</span>
  </div>

  <div class="max-w-[820px]">
    <p class="text-hero-lede m-0 text-foreground-light">
      A quiet corner of the internet with my{" "}
      <a href="#experience" class="link-noun hover:link-noun-hover">resume</a>,{" "}
      a few <a href="#projects" class="link-noun hover:link-noun-hover"
        >projects</a
      >, the <a href="#skills" class="link-noun hover:link-noun-hover">tools</a
      >{" "}
      I reach for,{" "}
      <a href="#education" class="link-noun hover:link-noun-hover"
        >what I studied</a
      >, and — before long — some{" "}
      <a href="#writing" class="link-noun hover:link-noun-hover">writing</a>.
    </p>
  </div>

  <div
    class="flex items-baseline gap-[18px] font-mono text-xs text-muted max-md:flex-wrap"
  >
    <a
      href={`mailto:${profile.email}`}
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      email
    </a>
    <a
      href={profile.social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      linkedin
    </a>
    <a
      href={profile.social.github}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      github
    </a>
    <span class="ml-auto opacity-70 max-md:ml-0">scroll ↓</span>
  </div>

  <div class="mt-4 flex flex-col max-md:mt-2">
    {
      rows.map((r, i) => (
        <a
          href={r.href}
          class:list={[
            "group flex items-baseline justify-between py-[18px] no-underline-anim text-foreground border-t border-border max-md:py-3.5",
            i === rows.length - 1 && "border-b border-border",
          ]}
        >
          <span class="font-heading text-[2.75rem] uppercase leading-none tracking-[1px] font-normal transition-colors group-hover:text-accent max-md:text-[1.75rem]">
            {r.label}
          </span>
          <span class="flex items-baseline gap-4 font-mono text-xs text-muted">
            {r.meta && <span>{r.meta}</span>}
            <span class="text-accent">{pad2(r.count)}</span>
          </span>
        </a>
      ))
    }
  </div>
</section>
