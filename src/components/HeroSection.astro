---
import type { ProfileData } from "~/data/profile";
import Icon from "./Icon.astro";

interface Props {
  profile: ProfileData;
}

const { profile } = Astro.props;
---

<section
  id="hero"
  class="flex min-h-screen flex-col gap-14 px-16 pt-24 pb-18 md:gap-14 md:px-16 md:pt-24 md:pb-18 max-md:min-h-auto max-md:gap-9 max-md:px-5 max-md:pt-12 max-md:pb-12"
>
  <div
    class="flex font-mono text-[11px] uppercase tracking-[1px] text-muted md:items-center md:justify-between max-md:flex-col max-md:items-start max-md:gap-1.5"
  >
    <span>{profile.name}</span>
    <span>Salt Lake City, UT, USA · 40.76° N · 111.89° W</span>
  </div>

  <div class="max-w-[820px]">
    <p class="text-hero-lede m-0 text-foreground-light">
      My corner of the internet for{" "}
      <a href="#experience" class="link-noun hover:link-noun-hover"
        >what I've built</a
      >,{" "}
      <a href="#code" class="link-noun hover:link-noun-hover"
        >what I'm learning</a
      >,{" "}
      <a href="#books" class="link-noun hover:link-noun-hover">books</a> I
      keep coming back to,{" "}
      <a href="#photos" class="link-noun hover:link-noun-hover">photos</a>,
      links, and occasional{" "}
      <a href="/blog" class="link-noun hover:link-noun-hover">writing</a>.
    </p>
  </div>

  <div
    class="flex items-center gap-5 font-mono text-xs text-muted max-md:flex-wrap"
  >
    <a
      href={`mailto:${profile.email}`}
      aria-label="Email"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      <Icon name="envelope" size={20} />
    </a>
    <a
      href={profile.social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      <Icon name="linkedin" size={20} />
    </a>
    <a
      href={profile.social.github}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      <Icon name="github" size={20} />
    </a>
    <span class="ml-auto uppercase tracking-[1px] opacity-70 max-md:ml-0">
      scroll ↓
    </span>
  </div>

  <div class="mt-auto flex max-w-[820px] flex-col gap-3 max-md:mt-0">
    <div
      class="font-mono text-[11px] uppercase tracking-[2px] text-accent"
    >
      now
    </div>
    <dl
      class="m-0 grid gap-x-6 gap-y-2 font-mono text-xs text-foreground-light md:grid-cols-[120px_1fr] max-md:grid-cols-1 max-md:gap-y-1 max-md:text-[11px]"
    >
      <dt class="uppercase tracking-[1.5px] text-muted">Building</dt>
      <dd class="m-0">Steady Grade Studios</dd>
      <dt class="uppercase tracking-[1.5px] text-muted">Studying</dt>
      <dd class="m-0">CS @ Oregon State</dd>
    </dl>
  </div>

  <div data-nav-sentinel aria-hidden="true"></div>
</section>
