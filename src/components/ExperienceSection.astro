---
import { cn } from "~/lib/cn";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";
import type { Experience } from "~/data/profile";

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<section
  id="experience"
  class="scroll-mt-8 border-t border-background-alt py-16 max-md:py-12"
>
  <SectionHeader>Experience</SectionHeader>
  <div class="flex flex-col gap-8">
    {
      experiences.map((exp, i) => (
        <div
          class={cn(
            "pb-6",
            i === 0 &&
              "rounded-lg border-l-4 border-accent bg-background-alt p-6"
          )}
        >
          <div class="mb-1 flex flex-wrap items-baseline justify-between gap-2 max-[480px]:flex-col max-[480px]:gap-1">
            <h3 class="text-h3 m-0 text-foreground">
              {exp.url ? (
                <a
                  href={exp.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-foreground hover:text-accent"
                >
                  {exp.company}{" "}
                  <Icon name="external-link" size={12} class="opacity-50" />
                </a>
              ) : (
                exp.company
              )}
            </h3>
            {exp.period && (
              <span class="text-body-xs italic text-muted">{exp.period}</span>
            )}
          </div>
          {exp.role && (
            <p class="my-1 text-body font-bold text-muted">{exp.role}</p>
          )}
          <p class="mt-2 leading-[1.5] text-foreground">{exp.description}</p>
        </div>
      ))
    }
  </div>
</section>
