---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";
import type { Experience } from "~/data/profile";

interface Props {
  experiences: Experience[];
  previewCount?: number;
}

const { experiences, previewCount = 4 } = Astro.props;
const chronological = experiences.filter((e) => !e.ongoing);
const preview = chronological.slice(0, previewCount);
const hasMore = experiences.length > preview.length;
---

<section
  id="experience"
  class="scroll-mt-8 min-h-[100svh] border-t border-border px-16 py-30 md:min-h-screen max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader
    num="01"
    title="Experience"
    kicker={`${experiences.length} roles`}
  />
  <div>
    {
      preview.map((e) => (
        <article class="grid items-baseline border-t border-border-soft py-7 md:grid-cols-[140px_minmax(0,1fr)_2fr] md:gap-10 max-md:grid-cols-1 max-md:gap-2 max-md:py-5">
          <div class="font-mono text-label uppercase tracking-[1px] text-muted md:pt-1.5">
            {e.period}
          </div>
          <div>
            <h3 class="text-h3 m-0 text-foreground">
              {e.url ? (
                <a
                  href={e.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-foreground hover:text-accent"
                >
                  {e.company}
                </a>
              ) : (
                e.company
              )}
            </h3>
            {e.role && (
              <div class="mt-1.5 font-mono text-label uppercase tracking-[1px] text-accent">
                {e.role}
              </div>
            )}
          </div>
          <p class="m-0 text-detail text-foreground-light">
            {e.description}
          </p>
        </article>
      ))
    }
  </div>
  {
    hasMore && (
      <div class="mt-7 max-md:mt-5">
        <a
          href="/experience"
          class="no-underline-anim font-mono text-caption uppercase tracking-[1px] text-accent hover:text-accent-dark"
        >
          full resume →
        </a>
      </div>
    )
  }
</section>
