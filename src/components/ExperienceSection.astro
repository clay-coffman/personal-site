---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";
import type { Experience } from "~/data/profile";

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<section
  id="experience"
  class="scroll-mt-8 border-t border-border px-16 py-30 max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader
    num="02"
    title="Experience"
    kicker={`${experiences.length} roles`}
  />
  <div>
    {
      experiences.map((e) => (
        <article class="grid items-baseline border-t border-border-soft py-7 md:grid-cols-[140px_minmax(0,1fr)_2fr] md:gap-10 max-md:grid-cols-1 max-md:gap-2 max-md:py-5">
          <div class="font-mono text-[11px] uppercase tracking-[1px] text-muted md:pt-1.5">
            {e.period}
          </div>
          <div>
            <h3 class="text-h3 m-0 text-foreground">{e.company}</h3>
            {e.role && (
              <div class="mt-1.5 font-mono text-[11px] uppercase tracking-[1px] text-accent">
                {e.role}
              </div>
            )}
          </div>
          <p class="m-0 leading-[1.6] text-foreground-light md:text-[15.5px] max-md:text-sm">
            {e.description}
          </p>
        </article>
      ))
    }
  </div>
</section>
