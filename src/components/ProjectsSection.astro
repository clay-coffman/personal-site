---
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";
import type { Project } from "~/data/profile";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section
  id="projects"
  class="scroll-mt-8 border-t border-background-alt py-16 max-md:py-12"
>
  <SectionHeader>Projects</SectionHeader>
  {
    projects.map((project) => (
      <div class="mb-6">
        <h3 class="text-h3-sm text-foreground">
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground hover:text-accent"
          >
            {project.title}{" "}
            <Icon name="external-link" size={12} class="opacity-50" />
          </a>
          {project.language && (
            <span class="ml-3 inline-block rounded-full bg-background-alt px-2.5 py-0.5 align-middle text-body-sm text-muted">
              {project.language}
            </span>
          )}
        </h3>
        <p class="mt-2 leading-[1.5] text-foreground">{project.description}</p>
      </div>
    ))
  }
</section>
