---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";

interface Props {
  skills: Record<string, string[]>;
}

const { skills } = Astro.props;
---

<section
  id="skills"
  class="scroll-mt-8 border-t border-border px-16 py-30 max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader num="04" title="Skills" kicker="current stack" />
  <div
    class="grid gap-16 md:grid-cols-3 max-md:grid-cols-1 max-md:gap-7"
  >
    {
      Object.entries(skills).map(([category, items]) => (
        <div>
          <div class="mb-3.5 border-b border-border-soft pb-2 font-mono text-[11px] uppercase tracking-[2px] text-accent">
            {category}
          </div>
          <div class="flex flex-col gap-2">
            {items.map((s) => (
              <div class="font-heading text-xl uppercase tracking-[0.5px] text-foreground font-normal max-md:text-lg">
                {s}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
