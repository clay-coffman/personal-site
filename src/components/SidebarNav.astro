---
import { cn } from "~/lib/cn";

const path = Astro.url.pathname;
const isHome = path === "/";
const isBooks = path === "/books";
const isBlog = path === "/blog" || path.startsWith("/blog/");

const sections = ["experience", "projects", "skills", "education"];
---

<aside
  class="fixed left-0 top-0 z-50 hidden h-screen w-[var(--sidebar-width)] items-center px-6 py-8 md:flex"
>
  <nav class="flex flex-col gap-4">
    <a
      href="/"
      class={cn(
        "no-underline-anim text-nav text-muted transition-colors hover:text-accent",
        isHome && "text-accent"
      )}
    >
      Home
    </a>
    <div
      class={cn(
        "flex flex-col gap-2 overflow-hidden pl-4 transition-all duration-300",
        isHome ? "max-h-[200px] opacity-100" : "max-h-0 opacity-0"
      )}
      style={isHome ? "margin-top: -0.5rem" : ""}
    >
      {
        sections.map((section) => (
          <a
            href={`/#${section}`}
            data-section={section}
            class="no-underline-anim text-body-sm text-muted/70 transition-colors hover:text-accent hover:opacity-100"
          >
            {section.charAt(0).toUpperCase() + section.slice(1)}
          </a>
        ))
      }
    </div>
    <a
      href="/books"
      class={cn(
        "no-underline-anim text-nav text-muted transition-colors hover:text-accent",
        isBooks && "text-accent"
      )}
    >
      Books
    </a>
    <a
      href="/blog"
      class={cn(
        "no-underline-anim text-nav text-muted transition-colors hover:text-accent",
        isBlog && "text-accent"
      )}
    >
      Blog
    </a>
  </nav>
</aside>
