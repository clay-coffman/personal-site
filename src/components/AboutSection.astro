---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";

const details = [
  { label: "Location", value: "Salt Lake City" },
  { label: "Studying", value: "CS @ Oregon State" },
  { label: "Reading", value: "The Three-Body Problem" },
  { label: "Building", value: "dotfiles, cc-notify" },
  { label: "Listening", value: "Bill Evans Trio" },
];
---

<section
  id="about"
  class="border-t border-border px-16 py-30 max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader num="01" title="About" kicker="a brief" />
  <div
    class="grid items-start gap-20 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] max-md:grid-cols-1 max-md:gap-8"
  >
    <div
      class="font-heading text-[1.625rem] leading-[1.5] text-foreground-light font-normal md:text-[1.625rem] max-md:text-xl"
    >
      <p class="m-0 mb-6">
        I've built a few companies — most recently <em>TradeFoundry</em>, a
        recruiting platform for the skilled trades. Before that, <em>Zego</em>
        {" "}(proptech, Techstars KC 2017) and some time at <em>CryptoSlam</em>.
      </p>
      <p class="m-0">
        Currently a CS student at Oregon State, focused on hardware and systems
        programming. In my spare time I angel-invest, do diligence work, read,
        and take photos of Utah.
      </p>
    </div>
    <dl
      class="m-0 border-l border-border pl-6 font-mono text-xs text-muted leading-[2]"
    >
      {
        details.map((d) => (
          <div class="flex gap-2">
            <dt class="text-foreground-light">{d.label}</dt>
            <dd class="m-0">{d.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
