---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";
import { photos } from "~/data/photos";

const preview = photos.slice(0, 3);
---

<section
  id="photos"
  class="scroll-mt-8 border-t border-border px-16 py-30 md:min-h-screen max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader num="05" title="Photos" kicker="Utah" />
  <div
    class="grid gap-5 md:grid-cols-3 max-md:grid-cols-2 max-md:gap-2.5"
  >
    {
      preview.map((ph) => (
        <figure class="m-0">
          <img
            src={ph.url}
            alt={ph.caption}
            width={ph.width}
            height={ph.height}
            loading="lazy"
            decoding="async"
            class="block w-full border border-border bg-background-alt"
            style={`aspect-ratio: ${ph.width}/${ph.height}`}
          />
          <figcaption class="mt-2 font-mono text-[11px] tracking-[0.5px] text-muted">
            {ph.caption}
          </figcaption>
        </figure>
      ))
    }
  </div>
  <div class="mt-7 max-md:mt-5">
    <a
      href="/photos"
      class="no-underline-anim font-mono text-xs uppercase tracking-[1px] text-accent hover:text-accent-dark"
    >
      all photos →
    </a>
  </div>
</section>
