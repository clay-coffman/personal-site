---
import { profileData } from "~/data/profile";

const year = new Date().getFullYear();
---

<footer
  class="flex items-baseline gap-10 border-t border-border px-16 pt-10 pb-8 md:flex-row max-md:flex-col max-md:items-start max-md:gap-4 max-md:px-5 max-md:pt-8 max-md:pb-6"
>
  <div class="font-mono text-caption tracking-[1px] text-muted">
    {profileData.location} · © {year} {profileData.name}
  </div>
  <div class="ml-auto flex gap-[18px] font-mono text-caption max-md:ml-0">
    <a
      href={`mailto:${profileData.email}`}
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      email
    </a>
    <a
      href={profileData.social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      linkedin
    </a>
    <a
      href={profileData.social.github}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      github
    </a>
    <a
      href="/rss.xml"
      class="no-underline-anim text-accent hover:text-accent-dark"
    >
      rss
    </a>
  </div>
</footer>
