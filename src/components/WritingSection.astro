---
import { getCollection } from "astro:content";
import NumberedSectionHeader from "./NumberedSectionHeader.astro";

const posts = (
  await getCollection("blog", ({ data }) => !data.draft || import.meta.env.DEV)
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "2-digit", month: "short" });
---

<section
  id="writing"
  class="scroll-mt-8 min-h-[100svh] border-t border-border px-16 py-30 md:min-h-screen max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader
    num="05"
    title="Writing"
    kicker={posts.length > 0 ? "recent" : "soon"}
  />
  <div class="grid gap-16 md:grid-cols-2 max-md:grid-cols-1 max-md:gap-8">
    <p class="text-section-lede m-0 text-foreground-light">
      Occasional notes on software, AI coding workflows, hardware/systems work
      I'm picking up in school, and reflections from past companies. Sporadic —
      I post when I have something worth saying.
    </p>
    <div>
      {
        posts.length === 0 ? (
          <div class="font-mono text-label uppercase tracking-[1px] text-muted">
            first posts coming soon
          </div>
        ) : (
          <>
            <div class="mb-3.5 font-mono text-label uppercase tracking-[2px] text-muted">
              Recent
            </div>
            {posts.map((p) => (
              <a
                href={`/writing/${p.id}`}
                class="group flex items-baseline justify-between border-t border-border-soft py-3 no-underline-anim text-foreground"
              >
                <span class="text-list-title text-foreground-light transition-colors group-hover:text-foreground">
                  {p.data.title}
                </span>
                <span class="font-mono text-label-xs uppercase tracking-[1px] text-muted">
                  {fmtDate(p.data.pubDate)}
                </span>
              </a>
            ))}
          </>
        )
      }
    </div>
  </div>
  <div class="mt-7 max-md:mt-5">
    <a
      href="/writing"
      class="no-underline-anim font-mono text-caption uppercase tracking-[1px] text-accent hover:text-accent-dark"
    >
      all writing →
    </a>
  </div>
</section>
