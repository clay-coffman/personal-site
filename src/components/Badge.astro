---
interface Props {
  variant?: "default" | "accent";
  class?: string;
}

const { variant = "default", class: className } = Astro.props;
---

<span
  class:list={[
    "inline-block rounded-full px-3 py-1 text-label-xs",
    variant === "default" && "bg-background-alt text-foreground",
    variant === "accent" && "bg-accent/10 text-accent",
    className,
  ]}
>
  <slot />
</span>
