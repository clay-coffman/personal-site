---
interface Props {
  num: string;
  title: string;
  kicker?: string;
}

const { num, title, kicker } = Astro.props;
---

<div class="flex items-baseline gap-6 md:gap-6 max-md:gap-3.5 mb-8 md:mb-12">
  <div
    class="font-mono text-xs tracking-[2px] text-accent md:min-w-11 min-w-8"
  >
    {num}
  </div>
  <h2 class="text-h1 m-0 text-foreground">{title}</h2>
  {
    kicker && (
      <div class="ml-auto font-mono text-[11px] uppercase tracking-[1px] text-muted">
        {kicker}
      </div>
    )
  }
</div>
