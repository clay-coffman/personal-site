---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";
import type { Project } from "~/data/profile";

interface Props {
  projects: Project[];
  skills: Record<string, string[]>;
}

const { projects, skills } = Astro.props;
const featured = projects.find((p) => p.featured);
const supporting = projects.filter((p) => !p.featured);
---

<section
  id="code"
  class="scroll-mt-8 border-t border-border px-16 py-30 md:min-h-screen max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader
    num="02"
    title="Code"
    kicker="current technical work"
  />

  <p
    class="m-0 mb-12 max-w-[820px] font-heading text-[1.625rem] leading-[1.5] text-foreground-light font-normal max-md:mb-8 max-md:text-xl"
  >
    I'm rebuilding technical depth in public: small tools, Linux/dev-environment
    work, web infrastructure, and experiments around AI coding workflows.
  </p>

  <div
    class="mb-14 grid gap-8 md:grid-cols-3 max-md:mb-10 max-md:grid-cols-1 max-md:gap-5"
  >
    {
      Object.entries(skills).map(([category, items]) => (
        <div>
          <div class="mb-2 border-b border-border-soft pb-2 font-mono text-[11px] uppercase tracking-[2px] text-accent">
            {category}
          </div>
          <div class="font-heading text-base uppercase tracking-[1px] text-foreground-light">
            {items.join(" · ")}
          </div>
        </div>
      ))
    }
  </div>

  <div
    class="grid gap-8 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] max-md:grid-cols-1 max-md:gap-5"
  >
    {
      featured && (
        <a
          href={featured.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block border-t-2 border-accent py-6 no-underline-anim text-foreground max-md:py-5"
        >
          {featured.eyebrow && (
            <div class="mb-2 font-mono text-[11px] uppercase tracking-[2px] text-accent">
              {featured.eyebrow}
            </div>
          )}
          <h3 class="text-h3 m-0 mb-3 text-foreground transition-colors group-hover:text-accent">
            {featured.title}
          </h3>
          <p class="m-0 mb-4 max-w-[560px] text-[15.5px] leading-[1.55] text-foreground-light max-md:text-sm">
            {featured.description}
          </p>
          {featured.metadata && featured.metadata.length > 0 && (
            <div class="mb-5 flex flex-wrap items-baseline gap-x-2.5 gap-y-1 font-mono text-[11px] uppercase tracking-[1px] text-muted">
              {featured.metadata.map((m, i) => (
                <>
                  {i > 0 && <span>·</span>}
                  <span>{m}</span>
                </>
              ))}
            </div>
          )}
          {featured.quote && (
            <blockquote class="m-0 mb-5 border-l-2 border-border-soft pl-3 text-[15px] italic leading-[1.55] text-foreground-light max-md:text-sm">
              {featured.quote}
            </blockquote>
          )}
          {featured.terminal && (
            <pre class="m-0 mb-5 overflow-x-auto border border-border-soft bg-background-alt px-4 py-3.5 font-mono text-[12.5px] leading-[1.55] text-foreground-light max-md:text-[11.5px]">
              {featured.terminal}
            </pre>
          )}
          <div class="flex items-baseline justify-between gap-3">
            <div class="flex items-baseline gap-3">
              {featured.status && (
                <span class="bg-accent-soft px-2 py-0.5 font-mono text-[10px] uppercase tracking-[1px] text-accent">
                  {featured.status}
                </span>
              )}
            </div>
            <div class="font-mono text-[11px] uppercase tracking-[1px] text-accent">
              view →
            </div>
          </div>
        </a>
      )
    }

    <div class="flex flex-col gap-5">
      {
        supporting.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border-t border-border-soft py-5 no-underline-anim text-foreground"
          >
            {p.eyebrow && (
              <div class="mb-1.5 font-mono text-[10px] uppercase tracking-[2px] text-muted">
                {p.eyebrow}
              </div>
            )}
            <h3 class="text-h3-sm m-0 mb-2 text-foreground transition-colors group-hover:text-accent">
              {p.title}
            </h3>
            <p class="m-0 mb-3 text-[14px] leading-[1.55] text-foreground-light max-md:text-sm">
              {p.description}
            </p>
            {p.metadata && p.metadata.length > 0 && (
              <div class="mb-3 flex flex-wrap items-baseline gap-x-2 gap-y-1 font-mono text-[10px] uppercase tracking-[1px] text-muted">
                {p.metadata.map((m, i) => (
                  <>
                    {i > 0 && <span>·</span>}
                    <span>{m}</span>
                  </>
                ))}
              </div>
            )}
            <div class="flex items-baseline justify-between gap-3">
              {p.status && (
                <span class="bg-accent-soft px-2 py-0.5 font-mono text-[10px] uppercase tracking-[1px] text-accent">
                  {p.status}
                </span>
              )}
              <div class="ml-auto font-mono text-[11px] uppercase tracking-[1px] text-accent">
                view →
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div class="mt-10 flex flex-wrap gap-x-6 gap-y-2 max-md:mt-7">
    <a
      href="/projects"
      class="no-underline-anim font-mono text-xs uppercase tracking-[1px] text-accent hover:text-accent-dark"
    >
      all projects →
    </a>
    <a
      href="/homelab"
      class="no-underline-anim font-mono text-xs uppercase tracking-[1px] text-accent hover:text-accent-dark"
    >
      homelab →
    </a>
  </div>
</section>
