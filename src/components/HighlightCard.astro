---
import Badge from "./Badge.astro";
import type { Highlight } from "~/data/highlights";

interface Props {
  highlight: Highlight;
}

const { highlight } = Astro.props;

const sourceHref = highlight.sourceUrl || highlight.readwiseUrl;
const formattedDate = highlight.highlightedAt
  ? new Date(highlight.highlightedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<article
  class="rounded-lg border border-border bg-background p-5 shadow-sm"
>
  <blockquote
    class="mb-4 border-l-2 border-accent/40 pl-4 text-body italic text-foreground"
  >
    {highlight.text}
  </blockquote>
  {
    highlight.note && (
      <p class="mb-4 text-body-sm text-muted">
        <span class="font-semibold">Note:</span> {highlight.note}
      </p>
    )
  }
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <p class="text-body-sm text-muted">
      —{" "}
      <a
        href={sourceHref}
        class="hover:text-accent"
        target="_blank"
        rel="noopener"
      >
        <em>{highlight.bookTitle}</em>
        {highlight.bookAuthor && <>, {highlight.bookAuthor}</>}
      </a>
    </p>
    {formattedDate && <time class="text-body-2xs text-muted">{formattedDate}</time>}
  </div>
  {
    highlight.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1">
        {highlight.tags.map((tag) => (
          <Badge>{tag}</Badge>
        ))}
      </div>
    )
  }
</article>
