---
import NumberedSectionHeader from "./NumberedSectionHeader.astro";
import type { Education } from "~/data/profile";

interface Props {
  education: Education[];
}

const { education } = Astro.props;
---

<section
  id="education"
  class="scroll-mt-8 border-t border-border px-16 py-30 md:min-h-screen max-md:px-5 max-md:py-16"
>
  <NumberedSectionHeader num="03" title="Education" />
  <div>
    {
      education.map((e) => (
        <div class="grid border-t border-border-soft py-6 md:grid-cols-[120px_1fr_auto] md:gap-10 max-md:grid-cols-1 max-md:gap-1 max-md:py-4.5">
          <div class="font-mono text-[11px] text-muted md:pt-1">
            {e.year || "—"}
          </div>
          <h3 class="text-h3-sm m-0 text-foreground md:text-[1.375rem]">
            {e.institution}
          </h3>
          <div class="font-mono text-xs text-foreground-light md:pt-1.5">
            {e.credential}
          </div>
        </div>
      ))
    }
  </div>
</section>
